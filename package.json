{
  "name": "mcp-fb-page",
  "version": "1.0.0",
  "description": "MCP server for managing Facebook Page posts — create, read, update, delete, and get insights",
  "type": "module",
  "bin": {
    "mcp-fb-page": "./build/mcp-facebook-stdio-server.js"
  },
  "files": [
    "build/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/mcp-facebook-stdio-server.ts --bundle --platform=node --format=esm --outfile=build/mcp-fb-page.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "facebook",
    "facebook-page",
    "modelcontextprotocol"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  }
}
